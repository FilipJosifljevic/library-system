{
  "title": "Library System Monitoring",
  "uid": "library-system",
  "tags": ["spring-boot", "library"],
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "includeAll": false,
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$service\"}",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 3,
      "title": "Live Threads",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$service\"}",
          "legendFormat": "Threads"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"$service\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Response Time p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"$service\"}[1m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"$service\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application=\"$service\"}[1m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"$service\", outcome=\"SERVER_ERROR\"}[1m])",
          "legendFormat": "5xx errors"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"$service\", outcome=\"CLIENT_ERROR\"}[1m])",
          "legendFormat": "4xx errors"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active HTTP Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "http_server_requests_active_seconds_count{application=\"$service\"}",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 8,
      "title": "GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$service\"}[1m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "DB Connection Pool (HikariCP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$service\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$service\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"$service\"}",
          "legendFormat": "Pending"
        }
      ]
    },
    {
      "id": 10,
      "title": "Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", area=\"nonheap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
